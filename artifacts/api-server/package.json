{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx ./src/index.ts",
    "build": "pnpm --filter @workspace/neuro-quest run build && tsx ./build.ts && tsx ./scripts/provision-monitors.ts && tsx ./scripts/provision-dashboards.ts",
    "monitors:provision": "tsx ./scripts/provision-monitors.ts",
    "monitors:check": "tsx ./scripts/provision-monitors.ts --check",
    "dashboards:provision": "tsx ./scripts/provision-dashboards.ts",
    "dashboards:check": "tsx ./scripts/provision-dashboards.ts --check",
    "backup:db": "tsx ./scripts/backup-db.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@clerk/express": "^2.1.6",
    "@replit/object-storage": "^1.0.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "openai": "^6.38.0",
    "pg": "^8.20.0",
    "stripe": "20.4.1",
    "web-push": "^3.6.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.27.3",
    "tsx": "catalog:"
  }
}
