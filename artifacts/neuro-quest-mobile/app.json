{
  "expo": {
    "name": "NQ Zen Pro",
    "slug": "neuro-quest-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "neuroquest",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070D09"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pro.neuroquestzen.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSHumanReadableCopyright": "© 2026 NeuroQuest LLC",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#070D09"
      },
      "package": "pro.neuroquestzen.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-iap",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "NeuroQuest reads your Heart Rate Variability, Sleep Analysis, and Step Count from Apple Health when you open the app, so we can compute your personal Neuro Resilience Score. Your individual readings are only used to show your own score; anything shared with your employer is anonymized into aggregates of 5 or more employees, and your name is never attached.",
          "background": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ec03c65f-26ac-4c59-a053-617a543396fe"
      }
    },
    "owner": "whitneyausbrooks"
  }
}
