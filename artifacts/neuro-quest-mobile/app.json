{
  "expo": {
    "name": "NQ Zen Pro",
    "slug": "neuro-quest-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "neuroquest",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070D09"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "Info.neuroquest.zenpro",
      "buildNumber": "2",
      "infoPlist": {
        "NSHumanReadableCopyright": "© 2026 NeuroQuest LLC",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#070D09"
      },
      "package": "app.replit.neuroquest"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-iap",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "NeuroQuest reads your heart rate variability, sleep, and step data from Apple Health to compute your personal Neuro-Resilience Score. Your individual data is never visible to your employer.",
          "NSHealthUpdateUsageDescription": "NeuroQuest does not write data back to Apple Health.",
          "background": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ec03c65f-26ac-4c59-a053-617a543396fe"
      }
    },
    "owner": "whitneyausbrooks"
  }
}
