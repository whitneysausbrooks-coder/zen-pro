{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "neuroquestzen.pro"
      },
      "ios": {
        "buildConfiguration": "Debug"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_DOMAIN": "neuroquestzen.pro"
      },
      "ios": {
        "buildConfiguration": "Release",
        "image": "latest",
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "neuroquestzen.pro"
      },
      "ios": {
        "simulator": true
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "whitneysausbrooks@icloud.com",
        "ascAppId": "6763640852",
        "appleTeamId": "XGP7472WPJ"
      }
    }
  }
}
